# ─── Database ────────────────────────────────────────────────────────────────
# Docker mode (used inside docker-compose services)
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@db:5432/invest_db

# Local development mode (used outside Docker)
DATABASE_URL_LOCAL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/invest_db

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=invest_db

# ─── JWT Security ─────────────────────────────────────────────────────────────
# ВАЖНО: Замените на длинную случайную строку (минимум 32 символа)!
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_HEX_STRING_AT_LEAST_32_CHARS

# Время жизни токена в минутах (по умолчанию 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Default Admin ────────────────────────────────────────────────────────────
# Пароль администратора, создаваемого при первом запуске
ADMIN_PASSWORD=Admin@12345!

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Список разрешённых источников, через запятую
# В продакшене укажите конкретный домен: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Prometheus ───────────────────────────────────────────────────────────────
# Включить /metrics endpoint (установите в "true" для продакшена)
ENABLE_METRICS=true

# ─── Proxy (опционально, для анти-блокировки коллектора) ─────────────────────
# Список прокси через запятую: http://user:pass@host:port,http://...
PROXY_LIST=

# Database — Docker mode (used inside docker-compose)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/invest_db

# Database — Local mode (used outside Docker, e.g. python init_db.py)
DATABASE_URL_LOCAL=postgresql+psycopg://postgres:postgres@localhost:5432/invest_db

# PostgreSQL container configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=invest_db
